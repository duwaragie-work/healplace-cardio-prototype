enum UserRole {
  GUEST
  REGISTERED_USER
  VERIFIED_USER 
  CONTENT_ADMIN
  ARTICLE_ADMIN
  ARTICLE_APPROVER
  KB_UPLOADER 
  KB_APPROVER 
  CHAT_REVIEWER
  SUPER_ADMIN
}

enum MenopauseStage {
  PERIMENOPAUSE
  MENOPAUSE
  POSTMENOPAUSE
  UNKNOWN
}

model User {
  id      String  @id @default(ulid())
  email   String? @unique
  name    String?
  pwdhash String?

  // Profile fields set during / after onboarding
  dateOfBirth              DateTime?      
  menopauseStage           MenopauseStage @default(UNKNOWN)
  timezone                 String?        // IANA identifier, e.g. "Asia/Colombo"
  primarySymptoms          Json?          // string[] — canonical symptom identifiers
  primarySymptomsOtherText String?        // free-text from the "Other" option

  isVerified          Boolean  @default(false)
  role                UserRole @default(GUEST)
  onboardingCompleted Boolean  @default(false)

  accounts      Account[]
  refreshTokens RefreshToken[]
  devices       Device[]
  authLogs      AuthLog[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
