model User {
  id         String  @id @default(cuid())
  email      String? @unique
  name       String?
  pwdhash    String?
  isVerified Boolean @default(false)

  accounts      Account[]
  refreshTokens RefreshToken[]
  otps          OtpCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
