enum CallStatus {
    UPCOMING
    COMPLETED
    MISSED
    CANCELLED
}

model ScheduledCall {
    id        String     @id @default(uuid())
    userId    String
    alertId   String?
    callDate  String
    callTime  String
    callType  String
    notes     String?
    status    CallStatus @default(UPCOMING)
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    deviationAlert DeviationAlert? @relation(fields: [alertId], references: [id])

    @@index([userId, status])
    @@index([status, callDate])
    @@index([alertId])
}
