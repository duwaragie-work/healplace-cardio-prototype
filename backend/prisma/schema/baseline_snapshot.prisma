model BaselineSnapshot {
  id                String         @id @default(uuid())
  userId            String
  computedForDate   DateTime       @db.Date
  baselineSystolic  Decimal?       @db.Decimal(5, 2)
  baselineDiastolic Decimal?       @db.Decimal(5, 2)
  baselineWeight    Decimal?       @db.Decimal(6, 2)
  sampleSize        Int?           @default(7)
  createdAt         DateTime       @default(now())
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntries    JournalEntry[]

  @@unique([userId, computedForDate])
  @@index([userId, computedForDate(sort: Desc)])
}
