model ContentView {
  id        String   @id @default(ulid())
  contentId String
  userId    String?
  deviceId  String?
  viewedAt  DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([userId])
  @@index([viewedAt])
}
