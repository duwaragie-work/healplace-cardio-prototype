model JournalEntry {
  id               String            @id @default(uuid())
  userId           String
  entryDate        DateTime          @db.Date
  systolicBP       Int?
  diastolicBP      Int?
  weight           Decimal?
  medicationTaken  Boolean?
  missedDoses      Int?              @default(0)
  symptoms         String[]
  teachBackAnswer  String?
  teachBackCorrect Boolean?
  notes            String?
  source           EntrySource       @default(MANUAL)
  sourceMetadata   Json?
  measurementTime  String?           // "08:30", "14:15" — HH:mm format
  snapshotId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deviationAlerts  DeviationAlert[]
  snapshot         BaselineSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate, measurementTime])
  @@index([userId, entryDate(sort: Desc)])
}

enum DeviationType {
  SYSTOLIC_BP
  DIASTOLIC_BP
  WEIGHT
  MEDICATION_ADHERENCE
}

enum DeviationSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
}

enum EscalationLevel {
  LEVEL_1
  LEVEL_2
}

enum CommunicationPreference {
  TEXT_FIRST
  AUDIO_FIRST
}

enum EntrySource {
  MANUAL
  HEALTHKIT
}
