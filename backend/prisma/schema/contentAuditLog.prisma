model ContentAuditLog {
  id        String   @id @default(ulid())
  contentId String
  event     String
  actorId   String?
  metadata  Json?
  createdAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([event])
  @@index([createdAt])
}
