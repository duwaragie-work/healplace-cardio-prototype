model AuthLog {
  id         String   @id @default(ulid())
  event      String
  identifier String?
  userId     String?
  method     String?
  deviceId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  success    Boolean  @default(false)
  errorCode  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([identifier])
  @@index([event])
  @@index([createdAt])
}
