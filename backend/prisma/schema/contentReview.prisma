enum ReviewType {
  EDITORIAL
  CLINICAL
}

enum ReviewOutcome {
  APPROVED
  APPROVED_WITH_MINOR_REVISIONS
  REJECTED
}

model ContentReview {
  id        String @id @default(ulid())
  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  versionNo Int // Which content version this review applies to

  reviewType ReviewType
  outcome    ReviewOutcome
  notes      String? // Required when outcome = REJECTED

  reviewedById String
  reviewedBy   User   @relation("ContentReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime @default(now())

  @@index([contentId])
  @@index([versionNo])
  @@index([reviewedById])
}
