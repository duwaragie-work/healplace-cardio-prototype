model User {
  id                      String                   @id @default(ulid())
  email                   String?                  @unique
  name                    String?
  pwdhash                 String?
  dateOfBirth             DateTime?
  timezone                String?
  communicationPreference CommunicationPreference?
  preferredLanguage       String?                  @default("en")
  riskTier                RiskTier?                @default(STANDARD)
  diagnosisDate           DateTime?
  primaryCondition        String?
  isVerified              Boolean                  @default(false)
  roles                   UserRole[]               @default([GUEST])
  onboardingStatus        OnboardingStatus         @default(NOT_COMPLETED)
  accountStatus           AccountStatus            @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  authLogs                AuthLog[]
  baselineSnapshots       BaselineSnapshot[]
  contentSubmitted        Content[]                @relation("ContentSubmittedBy")
  contentRatings          ContentRating[]          @relation("ContentRatings")
  contentReviews          ContentReview[]          @relation("ContentReviewedBy")
  deviationAlerts         DeviationAlert[]
  escalationEvents        EscalationEvent[]
  journalEntries          JournalEntry[]
  notifications           Notification[]
  refreshTokens           RefreshToken[]
  scheduledCalls          ScheduledCall[]
  sessions                Session[]
  userDevices             UserDevice[]
}

enum UserRole {
  GUEST
  REGISTERED_USER
  VERIFIED_USER
  CONTENT_ADMIN
  ARTICLE_ADMIN
  ARTICLE_APPROVER
  CONTENT_APPROVER
  KB_UPLOADER
  KB_APPROVER
  CHAT_REVIEWER
  SUPER_ADMIN
}

enum RiskTier {
  STANDARD
  ELEVATED
  HIGH
}

enum OnboardingStatus {
  NOT_COMPLETED
  COMPLETED
}

enum AccountStatus {
  ACTIVE
  BLOCKED
  SUSPENDED
}
