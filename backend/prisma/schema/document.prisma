model Document {
  id                 String           @id @default(uuid())
  sourceName         String
  sourceType         String
  sourceFormat       String
  sourceSize         Int
  sourceChunkCount   Int
  sourceResourceLink String
  sourceTags         String[]
  sourceActiveStatus Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  chunks             DocumentVector[]
}
