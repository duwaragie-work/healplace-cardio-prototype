# Environment Variables for HealPlace v2 Backend
# Copy this file to .env and fill in your actual values

# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker or local PostgreSQL):
DATABASE_URL="postgresql://healplace:healplace@localhost:5432/healplace_dev"
# Cloud (e.g. Prisma Postgres / AWS RDS):
# DATABASE_URL="postgres://user:password@host:5432/db?sslmode=require"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth (web redirect flow) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v2/auth/google/callback
WEB_APP_URL=http://localhost:3000

# ─── Apple Sign In (mobile + web) ──────────────────────────────────────────────
# Mobile: Bundle ID from your iOS app (for identityToken verification)
APPLE_CLIENT_ID=com.yourcompany.app
# Web: Services ID from Apple Developer Portal (for web redirect flow)
APPLE_SERVICES_ID=com.yourcompany.web
# Required for web flow:
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_CALLBACK_URL=http://localhost:8080/api/v2/auth/apple/callback
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
<your-apple-private-key-here>
-----END PRIVATE KEY-----"

# ─── Email / OTP (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@yourcompany.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="YourApp <support@yourcompany.com>"

# ─── Cookies ───────────────────────────────────────────────────────────────────
# 'lax'  → same-domain / subdomain (app.healplace.com + api.healplace.com)
# 'none' → cross-domain, MUST be served over HTTPS
COOKIE_SAME_SITE=lax

# ─── Application ───────────────────────────────────────────────────────────────
PORT=8080

# ─── Voice / ADK gRPC Service ─────────────────────────────────────────────────
# Local dev: point to the Python adk-service running on :50051
ADK_SERVICE_HOST=localhost
ADK_SERVICE_PORT=50051
# Railway private network (set in Railway dashboard):
# ADK_SERVICE_HOST=adk-service.railway.internal

# ─── Chat Specific Keys ────────────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=ministral-3b-2512
