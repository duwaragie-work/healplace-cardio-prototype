# ─── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=<your-google-ai-studio-api-key>
GEMINI_MODEL=gemini-3.1-flash-live-preview

# ─── gRPC server ───────────────────────────────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# ─── NestJS internal URL (for tool calls) ──────────────────────────────────────
# Local dev:
NESTJS_INTERNAL_URL=http://localhost:8080/api
# Railway private network (set in Railway dashboard):
# NESTJS_INTERNAL_URL=http://backend.railway.internal:8080/api
